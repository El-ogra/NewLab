<UserControl x:Class="NewLab.Views.Pages.PatientEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:NewLab.Converters"
             xmlns:helpers="clr-namespace:NewLab.Helpers.Interactions"
             helpers:GlobalShortcuts.RegisterOn="True"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowTestInfoCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="F8" Command="{Binding EditCommand}" />
        <KeyBinding Key="F9" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F10" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="F11" Command="{Binding PrintBarcodeCommand}" />
        <KeyBinding Key="F12" Command="{Binding PrintReceiptCommand}" />
        <KeyBinding Key="Enter" Command="{Binding KeyboardEnterCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <converters:EnumToArabicConverter x:Key="EnumToArabicConverter"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 1 (Right in RTL): Patient Data -->
        <Border Grid.Column="0" Margin="0,0,8,0" Padding="12" CornerRadius="8"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="بيانات المريض" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,12" Foreground="{StaticResource PrimaryBrush}"/>

                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="الاسم الكامل"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8"/>

                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="اللقب"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding AgeValue, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="العمر"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,4,0"/>
                        <ComboBox Grid.Column="1"
                                  materialDesign:HintAssist.Hint="الوحدة"
                                  SelectedItem="{Binding AgeUnit}"
                                  Margin="4,0,0,0"
                                  x:Name="AgeUnitCombo"/>
                    </Grid>

                    <ComboBox materialDesign:HintAssist.Hint="الجنس"
                              SelectedItem="{Binding Gender}"
                              Margin="0,0,0,8"
                              x:Name="GenderCombo"/>

                    <ComboBox materialDesign:HintAssist.Hint="نظام الفوترة"
                              SelectedItem="{Binding BillingSystem}"
                              Margin="0,0,0,8"
                              x:Name="BillingCombo"/>

                    <CheckBox Content="مهم" IsChecked="{Binding IsImportant}" Margin="0,0,0,8"/>

                    <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="رقم الهاتف"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8"/>

                    <TextBox Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="الرقم القومي"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8"/>

                    <ComboBox materialDesign:HintAssist.Hint="جهة الإحالة"
                              Text="{Binding SelectedReferralName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              ItemsSource="{Binding ReferralSuggestions}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,8"/>

                    <ComboBox materialDesign:HintAssist.Hint="نوع العينة الخارجية"
                              ItemsSource="{Binding AvailableSpecimenTypes}"
                              SelectedValue="{Binding ExternalSpecimenTypeId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,8"/>

                    <CheckBox Content="إخفاء جهة الإحالة في التقرير"
                              IsChecked="{Binding ReferralHiddenOnReport}" Margin="0,0,0,12"/>

                    <TextBlock Text="معلومات طبية" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8" Foreground="{StaticResource PrimaryBrush}"/>

                    <CheckBox Content="صيام" IsChecked="{Binding IsFasting}" Margin="0,0,0,4"/>

                    <TextBox Text="{Binding FastingHours, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="ساعات الصيام"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             IsEnabled="{Binding IsFasting}"
                             Margin="0,0,0,4"/>

                    <CheckBox Content="يعاني على مضادات التخثر"
                              IsChecked="{Binding IsOnAnticoagulant}" Margin="0,0,0,4"/>

                    <CheckBox Content="يعاني من علاج الكبد"
                              IsChecked="{Binding HasLiverTreatment}" Margin="0,0,0,4"/>

                    <CheckBox Content="يعاني من علاج فيروسي"
                              IsChecked="{Binding HasAntiviralTreatment}" Margin="0,0,0,4"/>

                    <CheckBox Content="يعاني من مضادات حيوية"
                              IsChecked="{Binding HasAntibiotic}" Margin="0,0,0,4"/>

                    <CheckBox Content="حامل"
                              IsChecked="{Binding IsPregnant}" Margin="0,0,0,4"/>

                    <CheckBox Content="مدخن"
                              IsChecked="{Binding IsSmoker}" Margin="0,0,0,8"/>

                    <TextBlock Text="ملاحظات" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="ملاحظات"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             Margin="0,0,0,8"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Column 2 (Middle): Available Tests -->
        <Border Grid.Column="1" Margin="4,0,4,0" Padding="12" CornerRadius="8"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="التحاليل المتاحة" FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,8" Foreground="{StaticResource PrimaryBrush}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <ComboBox Width="120" ItemsSource="{Binding AvailableTestListModes}"
                              SelectedItem="{Binding SelectedTestListMode}"
                              materialDesign:HintAssist.Hint="نوع القائمة" Margin="0,0,8,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToArabicConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Width="200"
                             Text="{Binding TestListFilter, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="بحث"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </StackPanel>

                <ListBox Grid.Row="2" ItemsSource="{Binding AvailableTests}"
                         SelectedItem="{Binding SelectedAvailableTest}"
                         DisplayMemberPath="TestName"
                         helpers:DoubleClickBehavior.Command="{Binding AddSelectedTestCommand}"
                         Margin="0,0,0,8"/>

                <Button Grid.Row="3" Content="إضافة التحليل"
                        Command="{Binding AddSelectedTestCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Stretch" Padding="16,8"/>
            </Grid>
        </Border>

        <!-- Column 3 (Left): Selected Tests + Calculations + Actions -->
        <Border Grid.Column="2" Margin="8,0,0,0" Padding="12" CornerRadius="8"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="التحاليل المختارة" FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,8" Foreground="{StaticResource PrimaryBrush}"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedTests}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="كود التحليل" Binding="{Binding LabTestId}" Width="80"/>
                        <DataGridTextColumn Header="اسم التحليل" Binding="{Binding TestName}" Width="*"/>
                        <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2" Content="إزالة الكل"
                        Command="{Binding RemoveAllTestsCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        HorizontalAlignment="Stretch" Padding="16,4" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" FontSize="14" Margin="0,0,0,4">
                    <Run Text="الإجمالي:" FontWeight="SemiBold"/>
                    <Run Text="{Binding TotalAmount, StringFormat={}{0:F2}}"/>
                </TextBlock>

                <Grid Grid.Row="4" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding DiscountValue, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="الخصم"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,4,0"/>
                    <CheckBox Grid.Column="1" Content="نسبة مئوية"
                              IsChecked="{Binding DiscountIsPercent}"
                              VerticalAlignment="Bottom" Margin="4,0,0,0"/>
                </Grid>

                <TextBox Grid.Row="5"
                         Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="المدفوع"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,4"/>

                <TextBlock Grid.Row="6" FontSize="14" Margin="0,0,0,8">
                    <Run Text="المتبقي:" FontWeight="SemiBold"/>
                    <Run Text="{Binding Remaining, StringFormat={}{0:F2}}"/>
                </TextBlock>

                <WrapPanel Grid.Row="7" HorizontalAlignment="Center">
                    <Button Content="إضافة"
                            Command="{Binding AddPatientCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="تعديل"
                            Command="{Binding EditCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="حذف"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="حفظ (F9)"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="موافق"
                            Command="{Binding ConfirmCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="إيصال"
                            Command="{Binding PrintReceiptCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="باركود"
                            Command="{Binding PrintBarcodeCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" Padding="16,8"/>
                    <Button Content="لاب اي دي"
                            Command="{Binding LookupLabIdCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" Padding="16,8"/>
                    <materialDesign:PopupBox Margin="4">
                        <materialDesign:PopupBox.ToggleContent>
                            <Button Content="مرضى اليوم" Style="{StaticResource MaterialDesignOutlinedButton}" Padding="16,8"/>
                        </materialDesign:PopupBox.ToggleContent>
                        <ItemsControl ItemsSource="{Binding TodayPatients}" MaxHeight="300">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalAlignment="Stretch" Padding="8,4"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding DataContext.SelectTodayPatientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            HorizontalContentAlignment="Right">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding LabId}" Foreground="Gray"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </materialDesign:PopupBox>
                    <Button Content="خالص"
                            Command="{Binding MarkAsPaidCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="4" Padding="16,8"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
