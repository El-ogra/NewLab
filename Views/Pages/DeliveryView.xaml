<UserControl x:Class="NewLab.Views.Pages.DeliveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:NewLab.Converters"
             xmlns:helpers="clr-namespace:NewLab.Helpers.Interactions"
             helpers:GlobalShortcuts.RegisterOn="True"
             FlowDirection="RightToLeft">
    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding BackToMainCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <converters:TestStatusToIconConverter x:Key="TestStatusToIconConverter"/>
        <converters:TestStatusToColorConverter x:Key="TestStatusToColorConverter"/>
        <converters:EnumToArabicConverter x:Key="EnumToArabicConverter"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 1: Patient list + search + filters -->
        <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Hidden barcode input -->
                <TextBox Grid.Row="0" x:Name="BarcodeInputBox"
                         Opacity="0" Focusable="True" Width="1" Height="1"
                         Margin="0" Padding="0"/>

                <!-- Search by code -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="بحث بالكود"
                             Text="{Binding SearchCode, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" Margin="0,0,8,0"/>
                    <Button Content="بحث" Command="{Binding SearchByCodeCommand}" Padding="12,4"/>
                </StackPanel>

                <!-- Date filters -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="من:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding FilterDateFrom}" Width="130" Margin="0,0,8,0"/>
                    <TextBlock Text="إلى:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding FilterDateTo}" Width="130"/>
                </StackPanel>

                <!-- Filter ComboBox -->
                <ComboBox Grid.Row="3" Margin="0,0,0,8"
                          ItemsSource="{Binding FilterModes}"
                          SelectedItem="{Binding FilterMode}"
                          materialDesign:HintAssist.Hint="الفلتر">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToArabicConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Patient list -->
                <ListBox Grid.Row="4"
                         ItemsSource="{Binding Patients}"
                         SelectedItem="{Binding SelectedPatient}"
                         VirtualizingPanel.IsVirtualizing="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <materialDesign:PackIcon Kind="{Binding AggregateStatus, Converter={StaticResource TestStatusToIconConverter}}"
                                                        Foreground="{Binding AggregateStatus, Converter={StaticResource TestStatusToColorConverter}}"
                                                        Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding FullName}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding IsImportant, Converter={StaticResource BoolToRedBrushConverter}}"
                                           FontWeight="{Binding IsImportant, Converter={x:Static converters:InverseBoolToVisibilityConverter.Instance}}"/>
                                <TextBlock Text="{Binding AttendanceNumber, StringFormat='[{0}]'}"
                                           Foreground="Gray" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Column 2: Patient tests + info -->
        <Border Grid.Column="1" Margin="4,0,4,0" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Patient info -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="{Binding SelectedPatient.FullName, FallbackValue='اختر مريضاً'}"
                               FontSize="18" FontWeight="Bold" Margin="0,0,0,4"
                               Foreground="{Binding SelectedPatient.IsImportant, Converter={StaticResource BoolToRedBrushConverter}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="رقم الحضور: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.AttendanceNumber}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="الجنس: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.Gender, Converter={StaticResource EnumToArabicConverter}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="العمر: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.AgeValue}"/>
                        <TextBlock Text=" "/>
                        <TextBlock Text="{Binding SelectedPatient.AgeUnit, Converter={StaticResource EnumToArabicConverter}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="رقم المعمل: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.LabId}" Cursor="Hand" MouseLeftButtonDown="LabId_MouseLeftButtonDown"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="كود الملف: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.FileCode}" Cursor="Hand" MouseLeftButtonDown="FileCode_MouseLeftButtonDown"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="كود الزيارة: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.VisitCode}" Cursor="Hand" MouseLeftButtonDown="VisitCode_MouseLeftButtonDown"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="عدد التحاليل: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedPatient.TestCount}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tests list -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PatientTests}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التحليل" Binding="{Binding TestName}" Width="*"/>
                        <DataGridTemplateColumn Header="الحالة" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource TestStatusToIconConverter}}"
                                                                 Foreground="{Binding Status, Converter={StaticResource TestStatusToColorConverter}}"
                                                                 Width="16" Height="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridCheckBoxColumn Header="كُتب" Binding="{Binding IsEntered}" Width="50"/>
                        <DataGridCheckBoxColumn Header="راجَع" Binding="{Binding IsReviewed}" Width="50"/>
                        <DataGridCheckBoxColumn Header="مطبوع" Binding="{Binding IsPrinted}" Width="50"/>
                        <DataGridCheckBoxColumn Header="مسلَّم" Binding="{Binding IsDelivered}" Width="50"/>
                        <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat='{}{0:F2}'}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Column 3: Summary + commands -->
        <Border Grid.Column="2" Margin="8,0,0,0" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <!-- Summary -->
                <TextBlock Text="ملخص" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="غير مُدخل: " Foreground="Gray"/>
                    <TextBlock Text="{Binding UnenteredCount}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="غير مستلم: " Foreground="Gray"/>
                    <TextBlock Text="{Binding UndeliveredCount}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="غير مطبوع: " Foreground="Gray"/>
                    <TextBlock Text="{Binding UnprintedCount}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="المتبقي: " Foreground="Gray"/>
                    <TextBlock Text="{Binding RemainingBalance, StringFormat='{}{0:F2}'}" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                </StackPanel>

                <!-- Actions -->
                <Button Content="تسليم يدوي" Command="{Binding DeliverManuallyCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,0,8" Padding="8,8"/>
                <Button Content="F5 - تحديث" Command="{Binding RefreshCommand}"
                        Margin="0,0,0,8" Padding="8,6"/>

                <!-- Settlement -->
                <TextBlock Text="تسديد حساب" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="المبلغ"
                         Text="{Binding SettlementAmount, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>
                <Button Content="تسديد" Command="{Binding SettleAccountCommand}"
                        Margin="0,0,0,12" Padding="8,6"/>

                <!-- Unmark delivered (Admin only) -->
                <Button Content="مستلمة (إلغاء)" Command="{Binding UnmarkDeliveredCommand}"
                        IsEnabled="{Binding IsAdmin}"
                        Background="{StaticResource SecondaryBrush}" Foreground="White"
                        Margin="0,0,0,12" Padding="8,6"/>

                <!-- Clear Account (Admin only) -->
                <Button Content="تصفية حساب" Command="{Binding ClearAccountCommand}"
                        IsEnabled="{Binding IsAdmin}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,0,12" Padding="8,6"/>

                <!-- Back -->
                <Button Content="العودة" Command="{Binding BackToMainCommand}"
                        Margin="0,0,0,4" Padding="8,6"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
