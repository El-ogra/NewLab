<UserControl x:Class="NewLab.Views.Pages.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:NewLab.Converters"
             FlowDirection="RightToLeft">
    <UserControl.InputBindings>
        <KeyBinding Key="F2" Command="{Binding OpenPatientDataCommand}" />
        <KeyBinding Key="F4" Command="{Binding OpenResultsCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="F10" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="Escape" Command="{Binding BackCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <converters:TestStatusToIconConverter x:Key="TestStatusToIconConverter"/>
        <converters:TestStatusToColorConverter x:Key="TestStatusToColorConverter"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Search filters -->
        <Border Grid.Row="0" Margin="0,0,0,8" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Right: Name/Phone/NationalId filters -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="بيانات المريض" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="بداية الاسم"
                                 Width="150" Margin="0,0,8,0"
                                 Text="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="يحتوي على"
                                 Width="150" Margin="0,0,8,0"
                                 Text="{Binding NameContains, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="رقم الهاتف"
                                 Width="150" Margin="0,0,8,0"
                                 Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="الرقم القومي"
                                 Width="150"
                                 Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Left: Code filters + Date/Age/Gender -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="أكواد المريض" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="كود الحالة"
                                 Width="120" Margin="0,0,8,0"
                                 Text="{Binding VisitCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="كود المعمل"
                                 Width="120" Margin="0,0,8,0"
                                 Text="{Binding LabCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="كود الملف"
                                 Width="120"
                                 Text="{Binding FileCode, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="من:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="130" Margin="0,0,8,0"/>
                        <TextBlock Text="إلى:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="130"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="عمر من"
                                 Width="70" Margin="0,0,8,0"
                                 Text="{Binding AgeFrom, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="عمر إلى"
                                 Width="70" Margin="0,0,8,0"
                                 Text="{Binding AgeTo, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Width="90" SelectedItem="{Binding SelectedAgeUnit}"
                                  materialDesign:HintAssist.Hint="وحدة العمر">
                            <ComboBoxItem Content="يوم"/>
                            <ComboBoxItem Content="شهر"/>
                            <ComboBoxItem Content="سنة"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="90" SelectedItem="{Binding SelectedGender}"
                                  materialDesign:HintAssist.Hint="الجنس" Margin="0,0,8,0">
                            <ComboBoxItem Content="ذكر"/>
                            <ComboBoxItem Content="أنثى"/>
                        </ComboBox>
                        <Button Content="F5 - بحث" Command="{Binding SearchCommand}" Padding="12,4"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Results DataGrid -->
        <Border Grid.Row="1" Margin="0,0,0,8" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedResult}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          VirtualizingPanel.IsVirtualizing="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الاسم" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="الجنس" Binding="{Binding Gender}" Width="50"/>
                        <DataGridTextColumn Header="السن" Binding="{Binding AgeValue}" Width="40"/>
                        <DataGridTextColumn Header="الهاتف" Binding="{Binding PhoneNumber}" Width="100"/>
                        <DataGridTextColumn Header="كود المعمل" Binding="{Binding LabId}" Width="80"/>
                        <DataGridTextColumn Header="الإحالة" Binding="{Binding ReferralName}" Width="80"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="1" Text="{Binding Results.Count, StringFormat='{}{0} نتيجة'}"
                           Foreground="Gray" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- Row 2: Selected patient tests + summary + commands -->
        <Border Grid.Row="2" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tests list -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="تحاليل المريض" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ListBox ItemsSource="{Binding SelectedResultTests}"
                             MaxHeight="120"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource TestStatusToIconConverter}}"
                                                            Foreground="{Binding Status, Converter={StaticResource TestStatusToColorConverter}}"
                                                            Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding LabTest.TestName}" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Summary + commands -->
                <StackPanel Grid.Column="1" Width="200" Margin="8,0,0,0">
                    <TextBlock Text="ملخص" FontWeight="Bold" Margin="0,0,0,4"/>
                    <StackPanel Margin="0,0,0,2">
                        <TextBlock Text="الإجمالي: " Foreground="Gray" FontSize="11"/>
                        <TextBlock Text="{Binding Summary.Total, StringFormat='{}{0:F2}'}" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,2">
                        <TextBlock Text="المدفوع: " Foreground="Gray" FontSize="11"/>
                        <TextBlock Text="{Binding Summary.Paid, StringFormat='{}{0:F2}'}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="المتبقي: " Foreground="Gray" FontSize="11"/>
                        <TextBlock Text="{Binding Summary.Remaining, StringFormat='{}{0:F2}'}" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" FontSize="11"/>
                    </StackPanel>

                    <!-- Commands -->
                    <Button Content="F4 - نتائج تحاليل" Command="{Binding OpenResultsCommand}"
                            Margin="0,0,0,4" Padding="8,4" FontSize="11"/>
                    <Button Content="F2 - بيانات مريض" Command="{Binding OpenPatientDataCommand}"
                            Margin="0,0,0,4" Padding="8,4" FontSize="11"/>
                    <Button Content="نتائج مجموعة" Command="{Binding PrintGroupResultsCommand}"
                            Margin="0,0,0,4" Padding="8,4" FontSize="11"/>
                    <Button Content="F10 - حذف (Admin)" Command="{Binding DeleteCommand}"
                            IsEnabled="{Binding IsAdmin}"
                            Background="{StaticResource SecondaryBrush}" Foreground="White"
                            Margin="0,0,0,8" Padding="8,4" FontSize="11"/>

                    <!-- Search source (Decision 12) -->
                    <TextBlock Text="مصدر البحث" FontWeight="Bold" Margin="0,0,0,4" FontSize="11"/>
                    <ComboBox SelectedItem="{Binding SelectedSource}" FontSize="11">
                        <ComboBoxItem Content="القاعدة الأساسية" Tag="Main"/>
                        <ComboBoxItem Content="النسخة الاحتياطية (غير مفعّل)" Tag="Backup"
                                      IsEnabled="False"
                                      ToolTip="غير مفعّل حالياً"/>
                    </ComboBox>

                    <Button Content="العودة" Command="{Binding BackCommand}"
                            Margin="0,8,0,0" Padding="8,4"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
