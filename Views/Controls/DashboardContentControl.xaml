<UserControl x:Class="NewLab.Views.Controls.DashboardContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:NewLab.ViewModels.Pages"
             xmlns:models="clr-namespace:NewLab.Models.Domain"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <StackPanel VerticalAlignment="Top">
        <TextBlock Text="{Binding SelectedCategory.Label}"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,16"
                   Foreground="{StaticResource PrimaryBrush}"/>
        <ItemsControl ItemsSource="{Binding SelectedCategory.Functions}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:FunctionDefinition}">
                    <Button Command="{Binding DataContext.OpenFunctionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Margin="8" Padding="16,12"
                            MinWidth="200" MinHeight="120">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="{Binding IconName, Converter={x:Static vm:IconNameToKindConverter.Instance}}"
                                                    Width="40" Height="40"
                                                    HorizontalAlignment="Center"
                                                    Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="15" FontWeight="Medium"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       Margin="0,10,0,0"
                                       MaxWidth="180"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>