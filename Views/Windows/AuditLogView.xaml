<Window x:Class="NewLab.Views.Windows.AuditLogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="سجل المراجعة"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Height="500" Width="700"
        MinHeight="400" MinWidth="500">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="سجل المراجعة" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- Patient Info -->
        <Border Grid.Row="1" Margin="0,0,0,8" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock FontWeight="Bold" Margin="0,0,0,4">
                    <Run Text="المريض: "/>
                    <Run Text="{Binding PatientName, Mode=OneWay}"/>
                </TextBlock>
                <DataGrid ItemsSource="{Binding PatientAudits}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="المستخدم" Binding="{Binding User.Username}" Width="100"/>
                        <DataGridTextColumn Header="الإجراء" Binding="{Binding Action}" Width="100"/>
                        <DataGridTextColumn Header="التفاصيل" Binding="{Binding Details}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Test Info -->
        <TextBlock Grid.Row="2" Text="{Binding TestName}" FontWeight="Bold" Margin="0,0,0,4"/>
        <Border Grid.Row="3" Padding="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <DataGrid ItemsSource="{Binding TestAudits}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="المستخدم" Binding="{Binding User.Username}" Width="100"/>
                    <DataGridTextColumn Header="الإجراء" Binding="{Binding Action}" Width="100"/>
                    <DataGridTextColumn Header="التفاصيل" Binding="{Binding Details}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
