<Window x:Class="NewLab.Views.Windows.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="New Lab System login" 
        Height="500" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None" 
        AllowsTransparency="True">
    
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding HandleEnterKeyCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="10" BorderThickness="1" BorderBrush="#CCCCCC">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" /> <!-- Green Top Section -->
                <RowDefinition Height="3*" /> <!-- Yellow Bottom Section -->
            </Grid.RowDefinitions>

            <!-- Top Green Section -->
            <Border Grid.Row="0" Background="#2E7D32" CornerRadius="10,10,0,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="New Lab System login" 
                               FontSize="24" FontWeight="Bold" Foreground="White" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Bottom Yellow Section -->
            <Border Grid.Row="1" Background="#FFC107" CornerRadius="0,0,10,10" Padding="40,15">
                <StackPanel VerticalAlignment="Center">
                    
                    <!-- Username -->
                    <TextBlock Text="User Name" Foreground="#1B5E20" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="User Name" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55"/>

                    <!-- Password -->
                    <TextBlock Text="Password" Foreground="#1B5E20" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="PwdBox" Height="55"
                                 materialDesign:HintAssist.Hint="Password" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>

                    <!-- Checkboxes -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="Show password" Foreground="#1B5E20" 
                                  IsChecked="{Binding ShowPassword}" FontSize="12"/>
                        <CheckBox Grid.Column="1" Content="Remember Login" Foreground="#1B5E20" 
                                  IsChecked="{Binding RememberLogin}" HorizontalAlignment="Right" FontSize="12"/>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold" 
                               Margin="0,8,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="12"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button Content="Sign In" Command="{Binding SignInCommand}" 
                                Width="120" Height="40" Margin="0,0,20,0"
                                Background="#4CAF50" Foreground="White" FontWeight="Bold"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                        <Button Content="Exit" Command="{Binding ExitApplicationCommand}" 
                                Width="120" Height="40"
                                Background="#F44336" Foreground="White" FontWeight="Bold"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock Text="SQL Server Database" Foreground="#1B5E20" FontStyle="Italic" FontSize="10" 
                               HorizontalAlignment="Right" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
