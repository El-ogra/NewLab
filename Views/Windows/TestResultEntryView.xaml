<Window x:Class="NewLab.Views.Windows.TestResultEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Test Result Entry"
        Height="750" Width="1100"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.InputBindings>
        <KeyBinding Key="F8" Command="{Binding ToggleReviewedCommand}" />
        <KeyBinding Key="F9" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F11" Command="{Binding PreviewCommand}" />
        <KeyBinding Key="F12" Command="{Binding PrintCommand}" />
        <KeyBinding Key="Escape" Command="{Binding BackCommand}" />
    </Window.InputBindings>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Patient info -->
        <Border Grid.Row="0" Padding="12" Margin="0,0,0,12" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding TestTitle}" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="الاسم" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Text="{Binding PatientName}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="رقم المعمل" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Text="{Binding PatientLabId}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الجنس" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Text="{Binding PatientGender}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="السن" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Text="{Binding PatientAge}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="تاريخ الزيارة" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Text="{Binding VisitDate, StringFormat='{}{0:yyyy-MM-dd}'}" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Row 1: Results DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="ResultDataGrid"
                  ItemsSource="{Binding ResultRows}"
                  SelectedItem="{Binding SelectedResultRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Element" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Normal Range" Binding="{Binding NormalRangeText}" IsReadOnly="True" Width="120"/>
                <DataGridTemplateColumn Header="Value" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     IsEnabled="{Binding IsEnabled}"
                                     Padding="4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" IsReadOnly="True" Width="70"/>
                <DataGridTemplateColumn Header="Flag" IsReadOnly="True" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding CellColor}">
                                <TextBlock Text="{Binding FlagText}" Padding="4" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Header="Rev" Binding="{Binding IsReviewed}" Width="40"/>
                <DataGridCheckBoxColumn Header="Prn" Binding="{Binding IsPrinted}" Width="40"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 2: Commands -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Comment + Saved Comments -->
            <StackPanel Grid.Column="0">
                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Comment"
                         Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                         Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PopupBox Margin="0,0,8,0">
                        <materialDesign:PopupBox.ToggleContent>
                            <Button Content="Saved Comments" Padding="12,6"/>
                        </materialDesign:PopupBox.ToggleContent>
                        <ItemsControl ItemsSource="{Binding SavedComments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding CommentText}"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding DataContext.PickSavedCommentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Right"
                                            Padding="8,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </materialDesign:PopupBox>
                    <Button Content="Comment from Normal Range"
                            Command="{Binding PickCommentFromNormalRangeCommand}"
                            Margin="0,0,8,0" Padding="12,6"/>
                    <Button Content="Undo Comment"
                            Command="{Binding UndoLastCommentCommand}"
                            Margin="0,0,8,0" Padding="12,6"/>
                </StackPanel>
            </StackPanel>

            <!-- Right: Action buttons -->
            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                <Button Content="F9 - Save" Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="4" Padding="12,8"/>
                <Button Content="F12 - Print" Command="{Binding PrintCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="4" Padding="12,8"/>
                <Button Content="F11 - Preview" Command="{Binding PreviewCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="4" Padding="12,8"/>
                <Button Content="F8 - Reviewed" Command="{Binding ToggleReviewedCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="4" Padding="12,8"/>
                <Button Content="{Binding HistoryButtonLabel}" Command="{Binding OpenHistoryCommand}"
                        Margin="4" Padding="12,8"/>
                <Button Content="Esc - Back" Command="{Binding BackCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="4" Padding="12,8"/>
                <Button Content="Main Menu" Command="{Binding MainMenuCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="4" Padding="12,8"/>
                <Button Content="Constants" Command="{Binding EditConstantsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="4" Padding="12,8"/>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
