<Window x:Class="NewLab.Views.Windows.NormalRangeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:controls="clr-namespace:NewLab.Views.Controls"
        Title="المعدل الطبيعي"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Test Name Header -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesignPaper}" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="التحليل: " FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ParentTest.TestName, FallbackValue=''}" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="  |  " FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="الكود: " FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ParentTest.Code, FallbackValue=''}" FontSize="14" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Row 1: Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <!-- Column 0 (Right in RTL): Ranges List -->
            <Border Grid.Column="0" Margin="0,0,10,0" Padding="5" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="المعدلات المسجلة" FontWeight="Bold" Margin="0,0,0,5" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Ranges}"
                             SelectedItem="{Binding SelectedRange}"
                             DisplayMemberPath=""
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Gender}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding AgeFrom}" />
                                        <Run Text="-" />
                                        <Run Text="{Binding AgeTo}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding AgeUnit}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding NormalRangeText}" Foreground="Gray" FontSize="11" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Column 1 (Center): Form -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="5">
                <StackPanel Margin="5">
                    <!-- Normal Section -->
                    <TextBlock Text="المعدل الطبيعي" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="الجنس" Margin="0,0,0,2" />
                            <ComboBox x:Name="GenderCombo"
                                      SelectedItem="{Binding FormGender}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="وحدة العمر" Margin="0,0,0,2" />
                            <ComboBox x:Name="AgeUnitCombo"
                                      SelectedItem="{Binding FormAgeUnit}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="العمر من" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormAgeFrom}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="من" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="العمر إلى" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormAgeTo}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="إلى" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="اسم التحليل" Margin="0,4,0,2" />
                    <TextBox x:Name="NormalRangeTextBox"
                             Text="{Binding FormTestName}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="اسم التحليل" />

                    <TextBlock Text="وحدة القياس" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormTestUnit}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="مثال: mg/dL" />

                    <TextBlock Text="المعدل الطبيعي (نص)" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormNormalRangeText}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="مثال: 70-110 mg/dL" />

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="الحد الأدنى" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormLowLimit}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="Low Limit" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="الحد الأقصى" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormHighLimit}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="High Limit" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="علامة المنخفض" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormLowFlag}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="Low Flag" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="علامة المرتفع" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormHighFlag}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="High Flag" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="تعليق المنخفض" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormLowComment}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Low Comment" />

                    <TextBlock Text="تعليق المرتفع" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormHighComment}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="High Comment" />

                    <!-- Critical Section -->
                    <TextBlock Text="المعدلات الحرجة" FontWeight="Bold" FontSize="14" Margin="0,12,0,8" />

                    <TextBlock Text="نص المعدل الحرج" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormCriticalRangeText}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Critical Range Text" />

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="الحد الأدنى للحرج" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormCriticalLowLimit}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="Critical Low" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="الحد الأقصى للحرج" Margin="0,0,0,2" />
                            <TextBox Text="{Binding FormCriticalHighLimit}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="Critical High" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="علامة التحذير" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormCriticalFlag}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Critical Flag" />

                    <TextBlock Text="تعليق التحذير" Margin="0,4,0,2" />
                    <TextBox Text="{Binding FormCriticalComment}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Critical Comment" />
                </StackPanel>
            </ScrollViewer>

            <!-- Column 2 (Left): Commands + Symbols Pad -->
            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                <TextBlock Text="الأوامر" FontWeight="Bold" Margin="0,0,0,8" />
                <Button Content="اضافة مدى"
                        Command="{Binding AddRangeCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Padding="16,8" />
                <Button Content="تعديل"
                        Command="{Binding EditCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Padding="16,8" />
                <Button Content="حفظ"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,4" Padding="16,8" />
                <Button Content="تراجع"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Padding="16,8" />
                <Button Content="حذف"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Padding="16,8"
                        Foreground="Red" />
                <Button Content="قائمة التحاليل"
                        Command="{Binding BackToTestsCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Padding="16,8"
                        Click="BackToTests_Click" />

                <Separator Margin="0,12" />

                <TextBlock Text="لوحة الرموز" FontWeight="Bold" Margin="0,0,0,4" />
                <controls:LatinSymbolsPad TargetTextBox="{Binding ElementName=NormalRangeTextBox}" />
            </StackPanel>
        </Grid>

        <!-- Row 2: Bottom Command Bar -->
        <Border Grid.Row="2" Padding="10" Margin="0,10,0,0" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="اضافة مدى"
                        Command="{Binding AddRangeCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="4" Padding="16,8" />
                <Button Content="تعديل"
                        Command="{Binding EditCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="4" Padding="16,8" />
                <Button Content="حفظ"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="4" Padding="16,8" />
                <Button Content="تراجع"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="4" Padding="16,8" />
                <Button Content="حذف"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="4" Padding="16,8"
                        Foreground="Red" />
                <Button Content="قائمة التحاليل"
                        Command="{Binding BackToTestsCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="4" Padding="16,8"
                        Click="BackToTests_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
