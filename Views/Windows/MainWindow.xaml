<Window x:Class="NewLab.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:NewLab.ViewModels.Pages"
        xmlns:models="clr-namespace:NewLab.Models.Domain"
        Title="NewLab - النظام الرئيسي" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        FlowDirection="RightToLeft">
    <Window.InputBindings>
        <KeyBinding Key="F2" Command="{Binding OpenPatientEntryCommand}" />
        <KeyBinding Key="F3" Command="{Binding OpenSearchCommand}" />
        <KeyBinding Key="F4" Command="{Binding OpenTestResultsListCommand}" />
        <KeyBinding Key="F6" Command="{Binding OpenDeliveryCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <DataTemplate DataType="{x:Type models:FunctionDefinition}">
            <Button Command="{Binding DataContext.OpenFunctionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                    Margin="8" Padding="16,12"
                    MinWidth="180" MinHeight="100">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="{Binding IconName, Converter={x:Static vm:IconNameToKindConverter.Instance}}"
                                            Width="36" Height="36"
                                            HorizontalAlignment="Center"
                                            Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="{Binding Name}"
                               FontSize="14" FontWeight="Medium"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryBrush}"
                Padding="8,4"
                Visibility="{Binding IsToolbarVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding ToolbarCategories}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ToolbarItem}">
                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="White"
                                Margin="2"
                                Padding="8,6"
                                ToolTip="{Binding Label}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="{Binding IconKind}" Width="24" Height="24" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" 
                                           FontSize="13" FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="16">
            <!-- Dashboard Mode: Show category name and function buttons -->
            <StackPanel Visibility="{Binding IsDashboardMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Top">
                <TextBlock Text="{Binding SelectedCategory.Label, StringFormat='{}{0}'}"
                           FontSize="24" FontWeight="Bold"
                           Margin="0,0,0,16"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <ItemsControl ItemsSource="{Binding SelectedCategory.Functions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:FunctionDefinition}">
                            <Button Command="{Binding DataContext.OpenFunctionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                    Margin="8" Padding="16,12"
                                    MinWidth="200" MinHeight="120">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="{Binding IconName, Converter={x:Static vm:IconNameToKindConverter.Instance}}"
                                                            Width="40" Height="40"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="15" FontWeight="Medium"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               Margin="0,10,0,0"
                                               MaxWidth="180"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Function Mode: Show placeholder with Back button -->
            <StackPanel Visibility="{Binding IsDashboardMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentFunction.Name}"
                           FontSize="24" FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <ContentControl Content="{Binding CurrentFunctionView}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                <Button Command="{Binding CloseFunctionCommand}"
                        Content="العودة للرئيسية"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Center"
                        Padding="24,8"
                        Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>